  "keyFeatures": [
    "JSON-RPC over stdio communication protocol compatible with VS Code Language Server Protocol",
    "Connection management for SQL Server, Azure SQL, and other SQL data sources",
    "Query execution with result set retrieval and export (CSV, JSON, XML, Excel)",
    "IntelliSense and language service features (completion, hover, diagnostics, go-to-definition)",
    "Object Explorer for browsing database objects hierarchically",
    "Schema comparison and DacFx operations (extract, deploy, import, export)",
    "SQL scripting and object script generation",
    "SQL Agent job management",
    "SQL Profiler for extended event session monitoring",
    "Table Designer for schema design",
    "SQL Projects support for database project files",
    "Azure authentication via MSAL with encrypted token cache"
  ],
